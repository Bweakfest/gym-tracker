{
  "name": "nexero",
  "scripts": {
    "start": "concurrently --names \"SERVER,CLIENT\" --prefix-colors \"cyan,green\" \"npm run server\" \"npm run client\"",
    "server": "cd server && node index.js",
    "client": "cd client && npx vite --port 5173"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0"
  }
}
